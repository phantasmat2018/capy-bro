<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!--
    Typographic tokens. Per project_design_guide.md §4.

    FontPrimary fallback chain (§4.1): Inter Variable is the eventual
    target but ships in Phase A task 2 (Logo + iconography) when fonts
    are bundled as embedded resources. For now we land on Segoe UI
    Variable (Win11) → Segoe UI (Win10) so the rest of the stack
    behaves correctly today. Updating the FontFamily resource swaps
    the entire app once Inter is available.
  -->

  <FontFamily x:Key="FontPrimary">Segoe UI Variable, Segoe UI</FontFamily>

  <!-- Type scale (§4.2) — TextBlock styles, applied via Style="{StaticResource TypeXxx}" -->

  <Style x:Key="TypeDisplay" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LineHeight" Value="36" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceStrongBrush}" />
  </Style>

  <Style x:Key="TypeH1" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="30" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceStrongBrush}" />
  </Style>

  <Style x:Key="TypeH2" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="26" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceStrongBrush}" />
  </Style>

  <Style x:Key="TypeH3" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="22" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceStrongBrush}" />
  </Style>

  <Style x:Key="TypeBodyStrong" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDefaultBrush}" />
  </Style>

  <Style x:Key="TypeBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDefaultBrush}" />
  </Style>

  <Style x:Key="TypeCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="LineHeight" Value="16" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceMutedBrush}" />
  </Style>

  <Style x:Key="TypeSmall" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontPrimary}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="LineHeight" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceMutedBrush}" />
  </Style>

  <!-- NOTE: an implicit `<Style TargetType="TextBlock">` was tried here as
       a backstop for ConfirmDialog body text (which used to render
       black-on-dark). It worked for that case, but it bled into the tray
       ContextMenu — WPF's default MenuItem template renders the header
       through a TextBlock that inherits this implicit style, and the
       OnSurfaceDefault foreground (light grey/white in dark theme)
       became invisible against the system-rendered light menu surface.
       Every TextBlock in our own views already declares either an
       explicit Style="{DynamicResource TypeXxx}" or an explicit
       Foreground, so the implicit fallback is redundant and the safer
       choice is to leave system-templated TextBlocks alone. -->

</ResourceDictionary>
