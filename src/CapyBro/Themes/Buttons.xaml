<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Button styles per project_design_guide.md §7.1-7.3 and §5.2 sizing.
    Four x:Key'd styles (no implicit Style overrides because Phase C
    sidebar tabs still rely on stock Button defaults until task 8):

      ButtonDefault      §7.1  Surface chrome, neutral border
      ButtonPrimary      §7.2  Brand.Primary CTA (large)
      ButtonDestructive  §7.3  Status.Error CTA (large) — Reset/Confirm-Delete
      ButtonIconOnly     §5.2  32x32 transparent, for Path-icon buttons

    Press animation: ScaleX/ScaleY 1.0 → 0.98 over 0:0:0.12 (= Motion.Fast,
    §8.1) on IsPressed enter; reverses on exit. Centered via
    RenderTransformOrigin="0.5,0.5". Reduce-motion fallback (§8.4) is a
    Phase D concern — current animation honours WPF's global animation
    enable/disable via SystemParameters.ClientAreaAnimation.

    Each Style declares its own ControlTemplate rather than sharing a
    base via BasedOn. Reason: the per-state colour triggers reference
    distinct DynamicResources per style (Surface.Layer* for Default vs
    Brand.Primary* for Primary), and Storyboards inside ControlTemplates
    can only resolve TargetName within their own NameScope. Inheriting
    via BasedOn and overriding the entire Template defeats the savings
    anyway. Verbosity here trades against templating-fragility.
  -->

  <!-- ==================== ButtonDefault (§7.1) ==================== -->
  <Style x:Key="ButtonDefault" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource SurfaceLayer1Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceStrongBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="FontFamily" Value="{DynamicResource FontPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="PressScale" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer3Brush}" />
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
              <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ==================== ButtonPrimary (§7.2) ==================== -->
  <Style x:Key="ButtonPrimary" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceInvertedBrush}" />
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="FontFamily" Value="{DynamicResource FontPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="PressScale" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrandPrimaryHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrandPrimaryPressedBrush}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <!-- Outer focus ring per §7.2 — render via 2px BorderBrush
                   on the same Border. The "outer with offset" treatment
                   is a layout refinement deferred to Phase D task 16. -->
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <!-- Spec'd disabled bg was BorderSubtle, but in the dark
                   palette BorderSubtle = SurfaceLayer2 — the disabled
                   CTA merged into the dialog body and read as
                   "missing button" (visible in the ModelsDialog
                   "Гаразд"-pre-selection state). Use Layer3 (one step
                   brighter than the dialog) + Opacity 0.7 so the
                   disabled state is obviously inactive but still
                   readable. -->
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer3Brush}" />
              <Setter TargetName="Root" Property="Opacity" Value="0.7" />
              <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ==================== ButtonDestructive (§7.3) ==================== -->
  <!-- Same dimensions as Primary CTA; Status.Error background. Hover/
       Pressed feedback via Opacity (no theme-specific darker-red token
       in §2.3.4) — black overlay would have been an alternative but
       opacity keeps the markup self-contained. -->
  <Style x:Key="ButtonDestructive" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource StatusErrorBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceInvertedBrush}" />
    <Setter Property="BorderBrush" Value="{x:Null}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="FontFamily" Value="{DynamicResource FontPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="8"
                  Padding="{TemplateBinding Padding}"
                  Opacity="1.0"
                  SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="PressScale" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.88" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.78" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.98" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.98" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderSubtleBrush}" />
              <Setter TargetName="Root" Property="Opacity" Value="1.0" />
              <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ==================== ButtonIconOnly (§5.2) ==================== -->
  <!-- 32x32 button for Path-icon glyphs (model-add / model-remove /
       browse-models / refresh-balance / Toast-cancel).
       Resting state now matches the other input controls — a tinted
       SurfaceLayer1 background + 1 px subtle border — so the affordance
       reads on the canvas before the user mouses over.  Pre-fix the
       resting background was Transparent, which made the icons
       indistinguishable from decorative glyphs against the dark surface
       (user feedback "the buttons should stand out, not only on hover").
       Hover bumps to SurfaceLayer2, pressed to SurfaceLayer3. -->
  <Style x:Key="ButtonIconOnly" TargetType="Button">
    <Setter Property="Background" Value="{DynamicResource SurfaceLayer1Brush}" />
    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDefaultBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <ScaleTransform x:Name="PressScale" ScaleX="1.0" ScaleY="1.0" />
            </Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer3Brush}" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.92" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.92" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12" />
                    <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BorderFocusBrush}" />
              <Setter TargetName="Root" Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDisabledBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
