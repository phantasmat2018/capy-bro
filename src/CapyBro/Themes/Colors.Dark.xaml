<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Dark theme raw color tokens. Per project_design_guide.md §2.3.
    Mirrors keys from Colors.Light.xaml; the only difference is the
    color values. Both files MUST declare the exact same x:Key set,
    otherwise the runtime theme swap will leave dangling DynamicResource
    references after switching from Dark → Light or vice-versa.
  -->

  <!-- Brand & accent (§2.3.1) -->
  <Color x:Key="BrandPrimaryColor">#FF7C9CFF</Color>
  <Color x:Key="BrandPrimaryHoverColor">#FF9DB5FF</Color>
  <Color x:Key="BrandPrimaryPressedColor">#FFB6C7FF</Color>
  <Color x:Key="AccentColor">#FFE879F9</Color>

  <!-- Surfaces (§2.3.2) -->
  <Color x:Key="SurfaceCanvasColor">#FF1A1B26</Color>
  <Color x:Key="SurfaceLayer1Color">#FF1E1E2E</Color>
  <Color x:Key="SurfaceLayer2Color">#FF27293D</Color>
  <Color x:Key="SurfaceLayer3Color">#FF313244</Color>
  <Color x:Key="SurfaceSidebarMicaColor">#FF181825</Color>

  <!-- On-surface text & icon (§2.3.3) -->
  <Color x:Key="OnSurfaceStrongColor">#FFF4F4F5</Color>
  <Color x:Key="OnSurfaceDefaultColor">#FFCDD6F4</Color>
  <Color x:Key="OnSurfaceMutedColor">#FF9398B8</Color>
  <Color x:Key="OnSurfaceDisabledColor">#FF585B70</Color>
  <Color x:Key="OnSurfaceInvertedColor">#FF18181B</Color>

  <!-- Status (§2.3.4) -->
  <Color x:Key="StatusSuccessColor">#FF4ADE80</Color>
  <Color x:Key="StatusErrorColor">#FFF87171</Color>
  <Color x:Key="StatusWarningColor">#FFFBBF24</Color>
  <Color x:Key="StatusInfoColor">#FF38BDF8</Color>

  <!-- Diff highlighting (used by the diff-preview modal). Subtle alpha
       tints so the underlying line text stays readable; saturated enough
       that scanning for changed lines is fast. -->
  <Color x:Key="DiffInsertBackgroundColor">#3322C55E</Color>
  <Color x:Key="DiffDeleteBackgroundColor">#33EF4444</Color>
  <Color x:Key="DiffModifiedBackgroundColor">#33F59E0B</Color>

  <!-- Borders (§2.3.5) -->
  <Color x:Key="BorderSubtleColor">#FF27293D</Color>
  <Color x:Key="BorderDefaultColor">#FF45475A</Color>
  <Color x:Key="BorderStrongColor">#FF6C7086</Color>
  <Color x:Key="BorderFocusColor">#FF7C9CFF</Color>

</ResourceDictionary>
