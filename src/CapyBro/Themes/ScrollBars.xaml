<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    ============ Single unified ScrollBar style for the whole app ============

    User feedback (May 2026): "Standardize the look of scrollbars in all
    inner windows: same look, thin, fit the design, with up/down arrows."

    History:
      • Phase E iteration 1: a 14-px Win11-style scrollbar with up/down
        chevron arrows + a 10-px-wide rectangular thumb.  Visually
        heavy in narrow lists.
      • Phase E iteration 7: a second, opt-in `ScrollBarThin` keyed
        style was added — 8 px wide, no arrows — and applied locally
        to History/Prompts list panes.  Two-style coexistence created
        visual fragmentation: the same control behaved differently
        depending on the host.
      • This iteration: collapse to ONE implicit style.  12 px wide
        (between the old 14 and the slim 8), top + bottom chevron
        arrow buttons preserved (some users rely on click-to-step),
        pill thumb (CornerRadius 3) with 1-px side margin so it
        floats inside the strip rather than touching its edges.

    Brush ladder for the thumb (kept identical to the previous thin
    variant — that one read as "elegant" in user feedback):
      • Idle:       BorderStrong  — clearly visible, soft tone.
      • Hover:      OnSurfaceMuted — slightly stronger.
      • Dragging:   OnSurfaceMuted — same stronger tone, no flash.

    Arrow buttons: 12 × 12 boxes with a 6×3 chevron in OnSurfaceMuted.
    Hover paints SurfaceLayer2 on the button background so the user
    sees they're clickable.

    ContextMenu is set to {x:Null} on the ScrollBar style — without
    that, right-click pops the system-localised "Прокрутка на месте /
    Наверх / Внизу / …" menu (presentationcore resources, not our
    Translator), which stays Russian regardless of the user's chosen
    UI language.  All actions in that menu are already covered by
    mouse wheel + arrow buttons + track click + drag-the-thumb +
    Home/End/PgUp/PgDn keys, so suppressing it costs nothing.

    Horizontal orientation handled at the bottom of the ControlTemplate
    via a -90° LayoutTransform on the root Grid, so the same template
    serves both axes.
  -->

  <!-- ============== Thumb (the draggable pill) ============== -->
  <Style x:Key="ScrollBarThumb" TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="Root"
                  Background="{DynamicResource BorderStrongBrush}"
                  CornerRadius="3"
                  Margin="{DynamicResource ScrollBarThumbMargin}" />
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource OnSurfaceMutedBrush}" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource OnSurfaceMutedBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============== Page-up / page-down RepeatButtons ============== -->
  <!-- Invisible click targets in the track area between thumb and arrow
       buttons. -->
  <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border Background="{TemplateBinding Background}" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============== Up/down arrow buttons at the ends ============== -->
  <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="Width" Value="12" />
    <Setter Property="Height" Value="12" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  CornerRadius="3">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============== ScrollBar (vertical/horizontal) ============== -->
  <Style TargetType="ScrollBar">
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Width" Value="12" />
    <Setter Property="MinWidth" Value="12" />
    <Setter Property="ContextMenu" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid x:Name="Bg" Background="{TemplateBinding Background}">
            <Grid.RowDefinitions>
              <RowDefinition Height="12" />
              <RowDefinition Height="*" />
              <RowDefinition Height="12" />
            </Grid.RowDefinitions>

            <!-- Up arrow.  6×3 chevron in OnSurfaceMuted.  Centered
                 inside a 12×12 button via the LineButton template's
                 ContentPresenter. -->
            <RepeatButton Grid.Row="0"
                          Style="{StaticResource ScrollBarLineButton}"
                          Command="ScrollBar.LineUpCommand">
              <Path Data="M 0 3 L 3 0 L 6 3"
                    Stroke="{DynamicResource OnSurfaceMutedBrush}"
                    StrokeThickness="1.2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="6"
                    Height="3"
                    Stretch="None" />
            </RepeatButton>

            <!-- Track + Thumb -->
            <Track x:Name="PART_Track"
                   Grid.Row="1"
                   IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                              Command="ScrollBar.PageUpCommand" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource ScrollBarThumb}" />
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                              Command="ScrollBar.PageDownCommand" />
              </Track.IncreaseRepeatButton>
            </Track>

            <!-- Down arrow.  Mirror of the up chevron. -->
            <RepeatButton Grid.Row="2"
                          Style="{StaticResource ScrollBarLineButton}"
                          Command="ScrollBar.LineDownCommand">
              <Path Data="M 0 0 L 3 3 L 6 0"
                    Stroke="{DynamicResource OnSurfaceMutedBrush}"
                    StrokeThickness="1.2"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="6"
                    Height="3"
                    Stretch="None" />
            </RepeatButton>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Width" Value="Auto" />
              <Setter Property="MinWidth" Value="0" />
              <Setter Property="Height" Value="12" />
              <Setter Property="MinHeight" Value="12" />
              <Setter TargetName="Bg" Property="LayoutTransform">
                <Setter.Value>
                  <RotateTransform Angle="-90" />
                </Setter.Value>
              </Setter>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
