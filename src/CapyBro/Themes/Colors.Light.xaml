<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Light theme raw color tokens. Per project_design_guide.md §2.3.
    Keys are referenced by Themes/Tokens.xaml via DynamicResource so
    runtime theme swap (Phase D) re-resolves brush colors.
    Do not use these keys directly from Views — use the *Brush keys
    from Tokens.xaml so theme swap propagates.
  -->

  <!-- Brand & accent (§2.3.1) -->
  <Color x:Key="BrandPrimaryColor">#FF3563E9</Color>
  <Color x:Key="BrandPrimaryHoverColor">#FF2849C9</Color>
  <Color x:Key="BrandPrimaryPressedColor">#FF1F3AAF</Color>
  <Color x:Key="AccentColor">#FFD946EF</Color>

  <!-- Surfaces (§2.3.2) -->
  <Color x:Key="SurfaceCanvasColor">#FFFAFAFA</Color>
  <Color x:Key="SurfaceLayer1Color">#FFFFFFFF</Color>
  <Color x:Key="SurfaceLayer2Color">#FFF4F4F5</Color>
  <Color x:Key="SurfaceLayer3Color">#FFE4E4E7</Color>
  <Color x:Key="SurfaceSidebarMicaColor">#FFF8F8F8</Color>

  <!-- On-surface text & icon (§2.3.3) -->
  <Color x:Key="OnSurfaceStrongColor">#FF18181B</Color>
  <Color x:Key="OnSurfaceDefaultColor">#FF3F3F46</Color>
  <Color x:Key="OnSurfaceMutedColor">#FF71717A</Color>
  <Color x:Key="OnSurfaceDisabledColor">#FFA1A1AA</Color>
  <Color x:Key="OnSurfaceInvertedColor">#FFFFFFFF</Color>

  <!-- Status (§2.3.4) -->
  <Color x:Key="StatusSuccessColor">#FF16A34A</Color>
  <Color x:Key="StatusErrorColor">#FFDC2626</Color>
  <Color x:Key="StatusWarningColor">#FFD97706</Color>
  <Color x:Key="StatusInfoColor">#FF0284C7</Color>

  <!-- Diff highlighting (used by the diff-preview modal). Light-theme
       analogues of the dark-theme alpha-tint variants. -->
  <Color x:Key="DiffInsertBackgroundColor">#3316A34A</Color>
  <Color x:Key="DiffDeleteBackgroundColor">#33DC2626</Color>
  <Color x:Key="DiffModifiedBackgroundColor">#33D97706</Color>

  <!-- Borders (§2.3.5) -->
  <Color x:Key="BorderSubtleColor">#FFE4E4E7</Color>
  <Color x:Key="BorderDefaultColor">#FFD4D4D8</Color>
  <Color x:Key="BorderStrongColor">#FFA1A1AA</Color>
  <Color x:Key="BorderFocusColor">#FF3563E9</Color>

</ResourceDictionary>
