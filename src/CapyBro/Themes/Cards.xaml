<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Section-card styles for tab content (General, Prompts, …).

    Pre-cardification each tab was a single flat Grid where every row
    was visually equivalent — the eye had to read every label to
    decide which fields related to which.  Cards group related fields
    and let the user skim by section heading first, drill into one
    section at a time.

    Originally lived as locally-scoped UserControl.Resources inside
    GeneralTab.xaml; promoted here when PromptsTab adopted the same
    idiom (Phase E iteration 2) so both tabs reference one source of
    truth.  Living in App.xaml's MergedDictionaries makes the keys
    available app-wide as StaticResource lookups.

    Visual grammar:
      • SectionCard          standard tier (BorderSubtle)
      • SectionCardBeta      experimental tier (StatusWarning border)
      • SectionCardDanger    destructive tier (StatusError border)
      • SectionAccentStrip   3-px BrandPrimary strip rendered to the
                             left of every regular section heading;
                             same pattern SidebarTabButton uses for
                             the "selected" indicator.

    Beta/Danger headings deliberately don't get the accent strip —
    they already have a status-coloured AlertTriangle glyph that
    plays the same "this section is special" role in their tier,
    keeping the strip exclusive to the regular tier preserves the
    three-tier visual hierarchy: brand → warning → error.
  -->

  <Style x:Key="SectionCard" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource SurfaceLayer1Brush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="20,16,20,16" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="SectionCardBeta" TargetType="Border" BasedOn="{StaticResource SectionCard}">
    <Setter Property="BorderBrush" Value="{DynamicResource StatusWarningBrush}" />
  </Style>

  <Style x:Key="SectionCardDanger" TargetType="Border" BasedOn="{StaticResource SectionCard}">
    <Setter Property="BorderBrush" Value="{DynamicResource StatusErrorBrush}" />
  </Style>

  <Style x:Key="SectionAccentStrip" TargetType="Border">
    <Setter Property="Width" Value="3" />
    <Setter Property="Background" Value="{DynamicResource BrandPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Margin" Value="0,2,10,2" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

</ResourceDictionary>
