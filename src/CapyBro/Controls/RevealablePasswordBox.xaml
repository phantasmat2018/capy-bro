<UserControl x:Class="CapyBro.Controls.RevealablePasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:CapyBro.Services"
             x:Name="Root">

  <!--
    Password input with an eye-toggle that swaps a masked PasswordBox
    for a plaintext TextBox when the user clicks the eye glyph.
    Closes project_design_guide.md §7.4 (last paragraph) and
    supersedes Controls/PasswordBoxBindable for the API-key field —
    PasswordBoxBindable stays in the codebase for future masked-only
    consumers if any.

    Why a UserControl rather than an attached behavior or a custom
    PasswordBox template: PasswordBox cannot reveal plaintext via
    PasswordChar alone (PasswordChar='\0' renders nothing, not the
    underlying string), so a sibling TextBox with visibility swap is
    the only path. UserControl encapsulates the swap + the binding
    sync in one self-contained surface and exposes a single Password
    DP that callers bind to.
  -->

  <!--
    Z9-F6 / L20 (refactored): the shared Cut/Copy/Paste ContextMenu
    that used to live here as a UserControl.Resources entry is now
    in Themes/Menus.xaml so EVERY input across the app (this control,
    plain InputTextBox via Setter, InputComboBox editable area)
    picks up the same dark-themed localised menu.  The PasswordBox +
    TextBox below still reference `InputCutCopyPasteMenu` by
    DynamicResource — same key, just resolved from App-level
    resources now.
  -->

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Stacked masked + plaintext inputs share the same row, only
         one is visible at a time. The masked one lives on top by
         default; ToggleButton flips Visibility on both. -->
    <Grid Grid.Column="0">
      <PasswordBox x:Name="MaskedInput"
                   Style="{DynamicResource InputPasswordBox}"
                   ContextMenu="{DynamicResource InputCutCopyPasteMenu}"
                   PasswordChanged="OnPasswordBoxChanged" />
      <TextBox x:Name="PlainInput"
               Style="{DynamicResource InputTextBox}"
               ContextMenu="{DynamicResource InputCutCopyPasteMenu}"
               Visibility="Collapsed"
               TextChanged="OnTextBoxChanged" />
    </Grid>

    <!-- Eye-toggle. We use a custom ControlTemplate so the toggle
         can swap its glyph between Icon.Eye (will reveal) and
         Icon.EyeOff (will conceal) under IsChecked, and so the row
         resting / hover affordance matches the rest of the
         ButtonIconOnly buttons (model add / remove / browse / refresh).
         Resting state uses the same SurfaceLayer1 + subtle border
         treatment so the toggle reads as an interactive control on the
         dark canvas before the user mouses over it — matches the user
         feedback "buttons should stand out, not only on hover". -->
    <ToggleButton x:Name="RevealToggle"
                  Grid.Column="1"
                  Width="32"
                  Height="32"
                  Margin="4,0,0,0"
                  Background="{DynamicResource SurfaceLayer1Brush}"
                  BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="1"
                  Cursor="Hand"
                  Focusable="True"
                  ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[tooltip_toggle_password]}"
                  AutomationProperties.Name="{Binding Source={x:Static services:Translator.Instance}, Path=[tooltip_toggle_password]}"
                  Checked="OnRevealChanged"
                  Unchecked="OnRevealChanged">
      <ToggleButton.Template>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  SnapsToDevicePixels="True">
            <Path x:Name="Glyph"
                  Data="{DynamicResource Icon.Eye}"
                  Stroke="{DynamicResource OnSurfaceMutedBrush}"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Width="16"
                  Height="16"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Glyph" Property="Data" Value="{DynamicResource Icon.EyeOff}" />
              <Setter TargetName="Glyph" Property="Stroke" Value="{DynamicResource OnSurfaceStrongBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </ToggleButton.Template>
    </ToggleButton>
  </Grid>
</UserControl>
