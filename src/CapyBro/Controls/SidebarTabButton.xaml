<UserControl x:Class="CapyBro.Controls.SidebarTabButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">

  <!--
    Sidebar tab-button per project_design_guide.md §7.8:
      Width=full (sidebar column), Height=40, Icon 20x20 left,
      Label `Body` weight SemiBold, 8 px gap.
      Selected: 3 px Brand.Primary indicator strip on the left edge +
      Surface.Layer2 background — matches the §7.7 list item idiom so
      a "selected" row in the sidebar visually rhymes with a selected
      row in any list inside the content pane.

    Internally we host a Button so keyboard nav + UIA accessibility
    come for free; the UserControl's IsSelected DP drives a
    DataTrigger on the inner Border, and Command/CommandParameter
    pass straight through to the Button.
  -->

  <Button x:Name="HostButton"
          Background="Transparent"
          BorderThickness="0"
          Padding="0"
          HorizontalContentAlignment="Stretch"
          Cursor="Hand"
          Command="{Binding Command, ElementName=Root}"
          CommandParameter="{Binding CommandParameter, ElementName=Root}"
          AutomationProperties.Name="{Binding Label, ElementName=Root}"
          Focusable="True">
    <Button.Template>
      <ControlTemplate TargetType="Button">
        <Border x:Name="RowBorder"
                Background="Transparent"
                Height="40"
                Padding="16,10"
                CornerRadius="6"
                SnapsToDevicePixels="True">
          <Grid>
            <!-- 3 px brand indicator on the left edge — flush with
                 the row, pulled into the Padding gutter so the icon
                 still sits 16 px from the visible edge. Visibility
                 is wired below by the IsSelected DataTrigger. -->
            <Border x:Name="SelectedIndicator"
                    Width="3"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource BrandPrimaryBrush}"
                    CornerRadius="2"
                    Margin="-16,4,0,4"
                    Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Path Data="{Binding Icon, ElementName=Root}"
                    Stroke="{DynamicResource OnSurfaceDefaultBrush}"
                    StrokeThickness="1.5"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="20"
                    Height="20"
                    Stretch="Uniform"
                    VerticalAlignment="Center" />
              <TextBlock Text="{Binding Label, ElementName=Root}"
                         FontFamily="{DynamicResource FontPrimary}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>
        <ControlTemplate.Triggers>
          <Trigger Property="IsMouseOver" Value="True">
            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
          </Trigger>
          <Trigger Property="IsKeyboardFocused" Value="True">
            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
          </Trigger>
          <DataTrigger Binding="{Binding IsSelected, ElementName=Root}" Value="True">
            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
            <Setter TargetName="SelectedIndicator" Property="Visibility" Value="Visible" />
          </DataTrigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
    </Button.Template>
  </Button>
</UserControl>
