<UserControl x:Class="CapyBro.Views.HistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:CapyBro.Services">

  <UserControl.Resources>
    <!--
      CollectionViewSource that wraps Entries and groups by relative
      date bucket (Today / Yesterday / This week / Older).
      HistoryDateBucketConverter (Services/) maps the DateTimeOffset
      to a localised bucket label.  Group ordering relies on the
      source list being sorted newest-first (HistoryStore.Snapshot
      guarantees this).
    -->
    <CollectionViewSource x:Key="EntriesView" Source="{Binding Entries}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="Timestamp">
          <PropertyGroupDescription.Converter>
            <services:HistoryDateBucketConverter />
          </PropertyGroupDescription.Converter>
        </PropertyGroupDescription>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </UserControl.Resources>

  <!--
    Phase E iteration 5: full redesign per user feedback that the
    previous layout still felt unpolished.  Goals:

      • Less chrome.  Drop the SurfaceLayer2 metadata sub-card and
        the hairline divider — both added visual weight without
        carrying their keep.
      • Cleaner typography rhythm.  Date-bucket headers are now
        small uppercase-feel muted labels (no SurfaceLayer2 band).
        Right-pane metadata is a single inline "time · model" line
        (no label-value form), with the prompt body as its own
        labelled block underneath.
      • Better breathing room.  16-px gaps between major right-
        pane sections (meta → prompt → original → improved) so
        the viewer reads as discrete chunks, not one wall of
        information.
      • Explicit empty state for the right pane when nothing is
        selected — pre-fix the right side rendered a hollow shell
        of empty TextBoxes that read as "broken".

    Single SectionCard wrapper keeps the cardified-tab grammar
    consistent with General + Prompts.
  -->
  <Grid Margin="24">
    <Border Style="{StaticResource SectionCard}">
      <DockPanel LastChildFill="True">

        <!--
          Header row: brand-accent strip + section title on the
          left, soft-destructive Clear All button on the right.
        -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Style="{StaticResource SectionAccentStrip}" />
            <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_title]}"
                       Style="{DynamicResource TypeH3}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <Button Grid.Column="1"
                  Command="{Binding ClearAllCommand}"
                  MinWidth="120">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                <Setter Property="Foreground" Value="{DynamicResource StatusErrorBrush}" />
                <Style.Triggers>
                  <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceDisabledBrush}" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource Icon.Trash2}"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="14" Height="14"
                    Stretch="Uniform"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <Path.Style>
                  <Style TargetType="Path">
                    <Setter Property="Stroke" Value="{DynamicResource StatusErrorBrush}" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsEnabled, RelativeSource={RelativeSource AncestorType=Button}}" Value="False">
                        <Setter Property="Stroke" Value="{DynamicResource OnSurfaceDisabledBrush}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Path.Style>
              </Path>
              <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_clear_all]}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>

        <!--
          Body: 2-column grid filling the remaining card height.
            Left column (260 px): search box stacked above the
              entries list.
            Right column (*):     details viewer for the selected
              entry, with explicit empty state when nothing is
              selected.
        -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Left column: search + grouped entries list -->
          <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Search row.  Same Search-icon prefix idiom as
                 ModelsDialog; bound to FilterText with a 150-ms
                 Delay so a fast typer doesn't thrash ApplyFilter.

                 Three layers in one Grid cell:
                   • TextBox (the actual input).
                   • Search glyph painted on the left (IsHitTestVisible
                     False so clicks fall through).
                   • Muted placeholder overlay (also IsHitTestVisible
                     False) bound to the same translator key the ToolTip
                     uses — pre-fix the box rendered with only the
                     magnifier and an empty area, leaving the user
                     guessing what to type.  The placeholder collapses
                     the moment FilterText becomes non-empty so it
                     never coexists with the user's text. -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
              <TextBox x:Name="SearchInput"
                       Style="{StaticResource InputTextBox}"
                       Padding="34,6,10,6"
                       Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                       ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[history_search_placeholder]}" />
              <Path Data="{DynamicResource Icon.Search}"
                    Stroke="{DynamicResource OnSurfaceMutedBrush}"
                    StrokeThickness="1.5"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="16" Height="16"
                    Stretch="Uniform"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False" />
              <TextBlock IsHitTestVisible="False"
                         Foreground="{DynamicResource OnSurfaceMutedBrush}"
                         FontFamily="{DynamicResource FontPrimary}"
                         FontSize="14"
                         Margin="36,0,12,0"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis"
                         Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_search_placeholder]}">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="">
                        <Setter Property="Visibility" Value="Visible" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Grid>

            <!-- ListBox + empty-state overlays layered in the same
                 Grid cell.  Two empty-state alternates (no-history
                 vs no-matches) wired via MultiDataTrigger. -->
            <Grid Grid.Row="1">
              <!--
                ScrollViewer.CanContentScroll="False" — pixel-based
                smooth scroll, matching ModelsDialog + PromptPickerWindow.
                Pre-fix item-based scroll with GroupStyle (date buckets)
                + mixed-height rows (group headers + ~60-px two-line
                entries) advanced 3 items per wheel notch, ~30 % of the
                visible area at typical Settings-window heights —
                noticeably "jumpy" to the user.  Perf trade is negligible:
                HistoryStore.DefaultCapacity caps the store at 50 entries
                so virtualization is overkill here.  IsVirtualizing kept
                at False so the panel materialises every row up-front
                (required for the pixel-scroll path; virtualization needs
                item-based scroll to know which rows to materialise).
              -->
              <ListBox x:Name="EntriesList"
                       Style="{StaticResource ListListBox}"
                       ItemsSource="{Binding Source={StaticResource EntriesView}}"
                       SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                       VirtualizingStackPanel.IsVirtualizing="False"
                       ScrollViewer.CanContentScroll="False">
                <ListBox.GroupStyle>
                  <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                      <DataTemplate>
                        <!--
                          Minimalist date-bucket header.  Pre-fix
                          the header had a SurfaceLayer2 background
                          band which competed with the right-pane
                          metadata sub-card visually.  Now: a
                          plain muted SemiBold caption, no fill,
                          left-aligned with light vertical padding
                          — reads as a quiet section divider.
                        -->
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   FontFamily="{DynamicResource FontPrimary}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="6,12,0,4" />
                      </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                  </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <!--
                      Two-line item template.  Line 1: original
                      snippet (SemiBold).  Line 2: time · model
                      (muted, smaller).  Prompt body intentionally
                      dropped from the row — the right-pane shows
                      it in full when selected, and stuffing it
                      here too made the row dense without giving
                      the user a complete answer.
                    -->
                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                      <TextBlock Text="{Binding Original}"
                                 Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"
                                 MaxWidth="220" />
                      <StackPanel Orientation="Horizontal"
                                  Margin="0,3,0,0"
                                  MaxWidth="220">
                        <!--
                          Z5-F1 / C8 fix: small glyph chip showing which
                          hotkey produced this entry (⌘ Default / ☰ Menu /
                          ↶ Undo).  Pre-fix HotkeyKind was decorative —
                          persisted in JSON, never surfaced in UI.
                        -->
                        <TextBlock Text="{Binding HotkeyKindGlyph}"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,4,0"
                                   ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[history_undo_hotkey]}" />
                        <TextBlock Text="{Binding Timestamp, Converter={x:Static services:HistoryTimestampConverter.Instance}}"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   FontSize="11" />
                        <TextBlock Text=" · "
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   FontSize="11" />
                        <TextBlock Text="{Binding Model}"
                                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="160" />
                      </StackPanel>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <!-- No-history (true empty store).
                   M14 (Z5-F6) fix: was matching FilterText against the
                   literal "" string, so a whitespace-only filter (which
                   ApplyFilter treats as empty) fell through into the
                   no-matches branch.  Bound to HasActiveFilter=false
                   instead, where the VM property is
                   !IsNullOrWhiteSpace — the two triggers are now
                   mutually exclusive on whitespace too. -->
              <StackPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="24"
                          IsHitTestVisible="False">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding Items.Count, ElementName=EntriesList}" Value="0" />
                          <Condition Binding="{Binding HasActiveFilter}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>

                <Path Data="{StaticResource Icon.History}"
                      Stroke="{DynamicResource OnSurfaceMutedBrush}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Width="40" Height="40"
                      Stretch="Uniform"
                      HorizontalAlignment="Center" />

                <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[empty_history_title]}"
                           Style="{DynamicResource TypeBodyStrong}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,4" />

                <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[empty_history_body]}"
                           Style="{DynamicResource TypeCaption}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="220" />
              </StackPanel>

              <!-- No-matches (filter active, no rows match).
                   M14 (Z5-F6) fix: was using NullToFalseConverter which
                   returns true for whitespace-only strings — so a user
                   who typed " " over an empty store saw the wrong "try
                   a different query" advice.  HasActiveFilter (which
                   tests !IsNullOrWhiteSpace) keeps the two empty-states
                   mutually exclusive. -->
              <StackPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Margin="24"
                          IsHitTestVisible="False">
                <StackPanel.Style>
                  <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding Items.Count, ElementName=EntriesList}" Value="0" />
                          <Condition Binding="{Binding HasActiveFilter}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                      </MultiDataTrigger>
                    </Style.Triggers>
                  </Style>
                </StackPanel.Style>

                <Path Data="{StaticResource Icon.Search}"
                      Stroke="{DynamicResource OnSurfaceMutedBrush}"
                      StrokeThickness="1.5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Width="40" Height="40"
                      Stretch="Uniform"
                      HorizontalAlignment="Center" />

                <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_no_matches]}"
                           Style="{DynamicResource TypeBodyStrong}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,4" />

                <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_no_matches_body]}"
                           Style="{DynamicResource TypeCaption}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="220" />
              </StackPanel>
            </Grid>
          </Grid>

          <!--
            Right column: details viewer.  Layered Grid:
              • Main content stack (visible when an entry is
                selected).
              • "Select an entry" placeholder (visible when
                SelectedEntry is null — typically only after
                ClearAll or before any selection has happened).

            Vertical rhythm of the main content stack:
              Row 0  Auto  meta header (time · model | trash)
              Row 1  Auto  prompt label + body
              Row 2  Auto  "Original" label row + copy button
              Row 3  *     Original textbox
              Row 4  Auto  "Improved" label row + copy button
              Row 5  *     Improved textbox

            Margin-bottom on each "Auto" block creates the 16-px
            rhythm between sections (12-px between the textbox
            above and the next label).
          -->
          <Grid Grid.Column="1">
            <!-- Main content (selected entry) -->
            <Grid>
              <Grid.Style>
                <Style TargetType="Grid">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedEntry}" Value="{x:Null}">
                      <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Grid.Style>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <!--
                Meta header.  Single inline "time · model" caption
                in muted brush + delete-entry icon button on the
                right.  Replaces the previous label-value form
                (Time / Model / Prompt rows in a sub-card) — that
                pattern read as a bureaucratic data-entry form,
                not a content viewer.  The single-line summary
                lets the eye land on the Original/Improved
                content faster.
              -->
              <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FormattedTime}"
                             Foreground="{DynamicResource OnSurfaceMutedBrush}"
                             FontFamily="{DynamicResource FontPrimary}"
                             FontSize="12"
                             VerticalAlignment="Center" />
                  <TextBlock Text=" · "
                             Foreground="{DynamicResource OnSurfaceMutedBrush}"
                             FontSize="12"
                             VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ModelName}"
                             Foreground="{DynamicResource OnSurfaceMutedBrush}"
                             FontFamily="{DynamicResource FontPrimary}"
                             FontSize="12"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource ButtonIconOnly}"
                        Command="{Binding DeleteSelectedCommand}"
                        ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_delete]}"
                        AutomationProperties.Name="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_delete]}"
                        VerticalAlignment="Center">
                  <Path Data="{StaticResource Icon.Trash2}"
                        Stroke="{DynamicResource OnSurfaceDefaultBrush}"
                        StrokeThickness="1.5"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Width="16" Height="16"
                        Stretch="Uniform" />
                </Button>
              </Grid>

              <!--
                Prompt block.  Caption label "Промт" above a
                muted-styled body that wraps to up to 3 lines,
                truncating with ellipsis if longer.  Separate
                section so the prompt is visible without being
                shoehorned into the meta header.
              -->
              <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_prompt]}"
                           Foreground="{DynamicResource OnSurfaceMutedBrush}"
                           FontFamily="{DynamicResource FontPrimary}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding PromptText}"
                           Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                           FontFamily="{DynamicResource FontPrimary}"
                           FontSize="13"
                           LineHeight="18"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="60" />
              </StackPanel>

              <!-- "Original" label + inline copy icon button on the right -->
              <Grid Grid.Row="2" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_original]}"
                           Style="{DynamicResource TypeBodyStrong}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Style="{StaticResource ButtonIconOnly}"
                        Command="{Binding CopyOriginalCommand}"
                        ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_copy_original]}"
                        AutomationProperties.Name="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_copy_original]}">
                  <Path Data="{StaticResource Icon.Copy}"
                        Stroke="{DynamicResource OnSurfaceDefaultBrush}"
                        StrokeThickness="1.5"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Width="16" Height="16"
                        Stretch="Uniform" />
                </Button>
              </Grid>

              <TextBox Grid.Row="3"
                       Style="{StaticResource InputTextBox}"
                       Text="{Binding OriginalText, Mode=OneWay}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       VerticalContentAlignment="Top" />

              <!-- "Improved" / "Результат" label row.  Mirrors the
                   "Original" row above (plain TypeBodyStrong label
                   + copy icon button) so the two read as siblings.
                   Earlier iterations decorated this row with a
                   StatusSuccess Check glyph and a green-tinted
                   border on the textbox below; user feedback was
                   that the green styling made the block feel
                   alarmist rather than neutral, so the
                   differentiation is now carried by section
                   ordering and headings alone. -->
              <Grid Grid.Row="4" Margin="0,16,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_improved]}"
                           Style="{DynamicResource TypeBodyStrong}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Style="{StaticResource ButtonIconOnly}"
                        Command="{Binding CopyImprovedCommand}"
                        ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_copy_improved]}"
                        AutomationProperties.Name="{Binding Source={x:Static services:Translator.Instance}, Path=[history_btn_copy_improved]}">
                  <Path Data="{StaticResource Icon.Copy}"
                        Stroke="{DynamicResource OnSurfaceDefaultBrush}"
                        StrokeThickness="1.5"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Width="16" Height="16"
                        Stretch="Uniform" />
                </Button>
              </Grid>

              <TextBox Grid.Row="5"
                       Style="{StaticResource InputTextBox}"
                       Text="{Binding ImprovedText, Mode=OneWay}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       VerticalContentAlignment="Top" />
            </Grid>

            <!--
              Empty placeholder for when no entry is selected.
              Visible only when SelectedEntry is null AND there
              IS at least one entry available — so we don't
              double-up on the left-pane "no history" message.
              Padding+IsHitTestVisible=False so it doesn't catch
              accidental clicks meant for the (hidden) main
              content.
            -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="24"
                        IsHitTestVisible="False">
              <StackPanel.Style>
                <Style TargetType="StackPanel">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <MultiDataTrigger>
                      <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding SelectedEntry}" Value="{x:Null}" />
                        <Condition Binding="{Binding HasEntries}" Value="True" />
                      </MultiDataTrigger.Conditions>
                      <Setter Property="Visibility" Value="Visible" />
                    </MultiDataTrigger>
                  </Style.Triggers>
                </Style>
              </StackPanel.Style>

              <!-- 40-px icon matches the no-history / no-matches empty
                   states on the left pane so all three empty messages
                   across the tab read at the same visual weight. -->
              <Path Data="{StaticResource Icon.History}"
                    Stroke="{DynamicResource OnSurfaceMutedBrush}"
                    StrokeThickness="1.5"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Width="40" Height="40"
                    Stretch="Uniform"
                    HorizontalAlignment="Center" />

              <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_select_entry_title]}"
                         Style="{DynamicResource TypeBodyStrong}"
                         HorizontalAlignment="Center"
                         Margin="0,12,0,4" />

              <!-- Body subtitle.  Mirrors the structure of the no-history
                   and no-matches empty states on the left pane (icon +
                   title + muted body) so all three empty states across
                   the tab read as one family. -->
              <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_select_entry_body]}"
                         Style="{DynamicResource TypeCaption}"
                         TextWrapping="Wrap"
                         TextAlignment="Center"
                         MaxWidth="240" />
            </StackPanel>
          </Grid>
        </Grid>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
