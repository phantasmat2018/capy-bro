<Window x:Class="CapyBro.Views.ModelsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding Source={x:Static services:Translator.Instance}, Path=[browse_models]}"
        Width="520"
        Height="480"
        MinWidth="420"
        MinHeight="320"
        Background="{DynamicResource SurfaceCanvasBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeResizeBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- Built-in: collapses elements when bound bool is false. -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!--
      CollectionViewSource that wraps the bound Models collection and
      groups the entries by provider prefix (everything before the
      "/" in an OpenRouter model id, e.g. "openai" / "anthropic").
      Pre-grouping the dialog rendered ~200 models as one flat
      alphabetical list — scanning by provider was slow.

      Source binding flows through the VM's `Models` property; when
      the user types in the filter box, ApplyFilter() reassigns
      Models to a new ObservableCollection, the binding picks up
      the new collection, and the view re-evaluates its groups.

      ProviderPrefixConverter (Services/) returns "other" for any
      id without a "/" so a malformed entry doesn't disappear; the
      group falls into a catch-all bucket at the bottom of the list.
    -->
    <CollectionViewSource x:Key="ModelsView" Source="{Binding Models}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription>
          <PropertyGroupDescription.Converter>
            <services:ProviderPrefixConverter />
          </PropertyGroupDescription.Converter>
        </PropertyGroupDescription>
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
  </Window.Resources>

  <DockPanel LastChildFill="True">

    <!-- Title text lives inside the dialog body as TypeH2 (§7.10),
         so the caption strip just shows close + drag region. -->
    <controls:WindowCaption DockPanel.Dock="Top"
                            ShowMinMax="False"
                            ShowTitle="False" />

    <!--
      §11 task 12 / §7.10 modal layout: H2 title, search-icon prefix
      on the filter, status line, and right-aligned action footer
      (Primary CTA right-most).
    -->
    <Grid Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- §7.10: dialog title at H2 typography for the in-content
           heading (the WindowCaption above also shows it in the strip
           for system parity). -->
      <TextBlock Grid.Row="0"
                 Text="{Binding Source={x:Static services:Translator.Instance}, Path=[browse_models]}"
                 Style="{DynamicResource TypeH2}"
                 Margin="0,0,0,16" />

      <!-- Filter row: search-icon prefix overlaid on a TextBox with
           left padding leaving room for the glyph (§11 task 12).
           Three layers — input + magnifier + muted placeholder
           overlay — mirroring the History tab's search treatment so
           every search box in the app reads with the same chrome. -->
      <Grid Grid.Row="1" Margin="0,0,0,12">
        <TextBox x:Name="ModelsFilterInput"
                 Style="{StaticResource InputTextBox}"
                 Padding="34,6,10,6"
                 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                 ToolTip="{Binding Source={x:Static services:Translator.Instance}, Path=[placeholder_search_models]}" />
        <Path Data="{DynamicResource Icon.Search}"
              Stroke="{DynamicResource OnSurfaceMutedBrush}"
              StrokeThickness="1.5"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              StrokeLineJoin="Round"
              Width="16" Height="16"
              Stretch="Uniform"
              Margin="12,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              IsHitTestVisible="False" />
        <TextBlock IsHitTestVisible="False"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   FontFamily="{DynamicResource FontPrimary}"
                   FontSize="14"
                   Margin="36,0,12,0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[placeholder_search_models]}">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding Text, ElementName=ModelsFilterInput}" Value="">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Grid>

      <!--
        ListBox + loading-overlay layered in a Grid so the spinner
        replaces the empty list during the initial /models fetch.
        Pre-fix the dialog opened with a stark empty pane for the
        ~1-3s catalogue download — no feedback at all.  IsLoading
        bool on the VM is set in try/finally so the overlay
        guarantees to clear even if the network call throws.
      -->
      <Grid Grid.Row="2">
        <!--
          ScrollViewer.CanContentScroll="False" → pixel-based smooth
          scroll instead of item-based.  With GroupStyle enabled WPF
          disables virtualization by default and the item-scroll mode
          treats each group header as a separate "item" with a
          different height than the rows below it; mouse-wheel
          deltas land on header-vs-row boundaries inconsistently and
          the user sees the list "skip" past 3-5 rows per wheel notch.
          Catalogue has ~200-400 entries — perf cost of disabling
          virtualization is negligible (~36 px per row, no images,
          plain text), and pixel scrolling is the only smooth UX with
          mixed-height rows.
        -->
        <ListBox x:Name="ModelsListBox"
                 ItemsSource="{Binding Source={StaticResource ModelsView}}"
                 SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                 Style="{StaticResource ListListBox}"
                 ScrollViewer.CanContentScroll="False">
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <!--
                    Provider header.  Earlier iteration used a
                    SurfaceLayer2-filled box at TypeBodyStrong size,
                    which read almost identically to a selected
                    list row (ListListBoxItem also paints
                    SurfaceLayer3 for selection — barely darker
                    than 2 in the dark palette).  The user reported
                    that group headers looked indistinguishable
                    from items.

                    New treatment matches HistoryTab's date-bucket
                    headers: small muted SemiBold caption with no
                    background.  The text-only style is impossible
                    to confuse with a clickable row and adds quiet
                    rhythm rather than competing visual weight.
                  -->
                  <TextBlock Text="{Binding Name}"
                             Foreground="{DynamicResource OnSurfaceMutedBrush}"
                             FontFamily="{DynamicResource FontPrimary}"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Margin="6,12,0,4" />
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
        </ListBox>

        <!--
          Loading overlay.  IsHitTestVisible=False so it doesn't
          swallow keyboard nav while a partial list is rendering —
          the empty list underneath has no rows to interact with
          anyway during the initial fetch.  Centered spinner +
          caption echoes the API-key validation indicator's
          treatment for visual consistency.
        -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    IsHitTestVisible="False"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
          <Path Data="{StaticResource Icon.Loader2}"
                Stroke="{DynamicResource OnSurfaceMutedBrush}"
                StrokeThickness="1.8"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                Width="32" Height="32"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
              <RotateTransform x:Name="ModelsLoadingRotate" Angle="0" />
            </Path.RenderTransform>
            <Path.Triggers>
              <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ModelsLoadingRotate"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360"
                                     Duration="0:0:1"
                                     RepeatBehavior="Forever" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </Path.Triggers>
          </Path>
          <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[msg_models_loading]}"
                     Style="{DynamicResource TypeCaption}"
                     HorizontalAlignment="Center"
                     Margin="0,12,0,0" />
        </StackPanel>

        <!--
          Z9-F1 / M24 fix: no-matches empty state, mirroring HistoryTab's
          shape so the dialog's empty-state grammar reads consistently
          with the rest of the app.  Pre-fix the user with a too-tight
          filter saw a hollow pane and only the row-3 status caption —
          visually indistinguishable from the loading-just-ended state.
          The MultiDataTrigger conditions are mutually exclusive with
          the loading overlay above (IsLoading=False) and with the
          empty-catalogue status text below (HasActiveFilter=True), so
          all three states never paint simultaneously.
        -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="24"
                    IsHitTestVisible="False">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <MultiDataTrigger>
                  <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Items.Count, ElementName=ModelsListBox}" Value="0" />
                    <Condition Binding="{Binding IsLoading}" Value="False" />
                    <Condition Binding="{Binding HasActiveFilter}" Value="True" />
                  </MultiDataTrigger.Conditions>
                  <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>

          <Path Data="{StaticResource Icon.Search}"
                Stroke="{DynamicResource OnSurfaceMutedBrush}"
                StrokeThickness="1.5"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                StrokeLineJoin="Round"
                Width="40" Height="40"
                Stretch="Uniform"
                HorizontalAlignment="Center" />

          <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[models_no_matches]}"
                     Style="{DynamicResource TypeBodyStrong}"
                     HorizontalAlignment="Center"
                     Margin="0,12,0,4" />

          <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[models_no_matches_body]}"
                     Style="{DynamicResource TypeCaption}"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     MaxWidth="240" />
        </StackPanel>
      </Grid>

      <TextBlock Grid.Row="3"
                 Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource OnSurfaceMutedBrush}"
                 Style="{DynamicResource TypeCaption}"
                 Margin="0,8,0,0"
                 TextWrapping="Wrap" />

      <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
        <Button x:Name="CancelButton"
                Style="{StaticResource ButtonDefault}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[btn_cancel]}"
                Click="CancelButton_Click"
                IsCancel="True"
                MinWidth="80" Margin="0,0,8,0" />
        <Button x:Name="OkButton"
                Style="{StaticResource ButtonPrimary}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[btn_ok]}"
                Click="OkButton_Click"
                IsDefault="True"
                IsEnabled="{Binding SelectedModel, Converter={x:Static services:NullToFalseConverter.Instance}}"
                MinWidth="80" />
      </StackPanel>
    </Grid>
  </DockPanel>
</Window>
