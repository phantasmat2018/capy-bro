<Window x:Class="CapyBro.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="440"
        SizeToContent="Height"
        Background="{DynamicResource SurfaceCanvasBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Title="{Binding Title}">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeFixedBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <DockPanel LastChildFill="True">
    <!-- Title is rendered inline in the body (15 px SemiBold), so the
         caption strip is just close + drag region. -->
    <controls:WindowCaption DockPanel.Dock="Top"
                            ShowMinMax="False"
                            ShowTitle="False" />
    <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!--
      Title row.  Phase E iteration 2: AlertTriangle glyph in
      StatusError next to the title text reinforces the "stop and
      think" beat for destructive confirms.  ConfirmDialog is used
      exclusively for irreversible actions (Reset Settings, Clear
      History) — the icon + colour do at a glance what the body
      copy does in prose.

      Horizontal StackPanel rather than a Grid because the title
      width is already constrained by the dialog's 440-px Width
      and TextBlock auto-wraps; a 2-column grid would buy us
      nothing extra and add markup overhead.
    -->
    <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,10">
      <Path Data="{StaticResource Icon.AlertTriangle}"
            Stroke="{DynamicResource StatusErrorBrush}"
            StrokeThickness="1.8"
            StrokeStartLineCap="Round"
            StrokeEndLineCap="Round"
            StrokeLineJoin="Round"
            Width="20" Height="20"
            Stretch="Uniform"
            VerticalAlignment="Center"
            Margin="0,0,10,0" />
      <TextBlock Text="{Binding Title}"
                 FontWeight="SemiBold"
                 FontSize="15"
                 Foreground="{DynamicResource OnSurfaceStrongBrush}"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap" />
    </StackPanel>

    <TextBlock Grid.Row="1"
               Text="{Binding Body}"
               TextWrapping="Wrap"
               Foreground="{DynamicResource OnSurfaceDefaultBrush}"
               Margin="0,0,0,18" />

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Style="{StaticResource ButtonDefault}"
              Content="{Binding Source={x:Static services:Translator.Instance}, Path=[btn_cancel]}"
              IsCancel="True"
              MinWidth="90" Margin="0,0,8,0"
              Click="Cancel_Click" />
      <Button Style="{StaticResource ButtonDestructive}"
              Content="{Binding ConfirmText}"
              IsDefault="True"
              MinWidth="90"
              Click="Confirm_Click" />
    </StackPanel>
    </Grid>
  </DockPanel>
</Window>
