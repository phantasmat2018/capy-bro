<Window x:Class="CapyBro.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CapyBro.ViewModels"
        xmlns:views="clr-namespace:CapyBro.Views"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="1040"
        Height="680"
        MinWidth="940"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Title="{Binding Source={x:Static services:Translator.Instance}, Path=[settings_title]}">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeResizeBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <DataTemplate DataType="{x:Type vm:GeneralTabViewModel}">
      <views:GeneralTab />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PromptsTabViewModel}">
      <views:PromptsTab />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
      <views:HistoryTab />
    </DataTemplate>
  </Window.Resources>

  <DockPanel LastChildFill="True">

    <!-- Custom 36 px caption strip — sidebar wordmark already shows
         the title, so the caption hides its title text. -->
    <controls:WindowCaption DockPanel.Dock="Top"
                            Title="{Binding Source={x:Static services:Translator.Instance}, Path=[settings_title]}"
                            ShowMinMax="True"
                            ShowTitle="False" />

    <!-- Sidebar at 224 px per §5.4: 180 was too tight for the
         icon + label row of SidebarTabButton. Background stays the
         documented SurfaceSidebarMicaBrush so the sidebar reads as a
         solid divider against the (Mica-tinted, on Win11) content
         pane — same idiom as Win11 Settings. -->
    <Border DockPanel.Dock="Left"
            Width="224"
            Background="{DynamicResource SurfaceSidebarMicaBrush}">
      <DockPanel LastChildFill="False">

        <!-- Sidebar header (capybara + "CapyBro" wordmark) was
             previously the top element of this DockPanel via
             header.png, but per user feedback it dominated the
             224-px sidebar even at MaxWidth=140 and pushed the
             navigation rows down by ~120 px without earning that
             space — the WindowCaption already shows the app title
             ("Налаштування" / "Settings"), and the system tray
             plus taskbar already show the brand icon, so the
             sidebar wordmark was redundant.  Removed entirely
             rather than just shrunk so the navigation can start
             flush with the top edge for faster scanning.

             The version footer (DockPanel.Dock=Bottom) below
             remains as the single brand-adjacent element on the
             sidebar — quiet enough to read as build metadata
             rather than as a header. -->

        <!-- Sidebar footer.  Iteration history (kept here as a
             cautionary trail because the visual brief kept moving):
               1. plain muted "capybro.app" text-link → read as
                  decorative caption, not an affordance.
               2. globe icon + full https URL in BrandPrimary +
                  underline → too loud, the brand-blue underlined
                  link competed with the SidebarTabButton selection
                  state for visual weight.
               3. (current) "v2.0.0 · capybro.app" on a single
                  horizontal line, mid-dot separator, host-only
                  display.  Both segments share TypeCaption +
                  OnSurfaceMuted by default so the row reads as a
                  single quiet metadata strip.  Hover on the link
                  half lifts to BrandPrimary; no underline at any
                  state — the cursor change and colour-shift are
                  sufficient affordance for a footer link, and the
                  underline was adding visual noise.
             A 1-px BorderSubtle line above the row separates the
             metadata strip from the SidebarTabButton column,
             matching the Win11 Settings idiom. -->
        <StackPanel DockPanel.Dock="Bottom">
          <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="0,1,0,0"
                  Margin="14,0,14,0" />

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="8,14,8,16">
            <TextBlock Text="{x:Static services:AppInfo.DisplayVersion}"
                       Style="{DynamicResource TypeCaption}"
                       VerticalAlignment="Center" />

            <!-- 3-px circular dot as separator.  Sized smaller than
                 the caption x-height so it reads as punctuation, not
                 as another character.  OnSurfaceDisabled (the dimmest
                 on-surface token) keeps it from competing with the
                 actual text for visual weight. -->
            <Ellipse Width="3" Height="3"
                     Fill="{DynamicResource OnSurfaceDisabledBrush}"
                     Margin="8,0,8,0"
                     VerticalAlignment="Center" />

            <TextBlock Style="{DynamicResource TypeCaption}"
                       VerticalAlignment="Center">
              <Hyperlink NavigateUri="{x:Static services:AppInfo.Homepage}"
                         RequestNavigate="OnHomepageLinkClick">
                <Hyperlink.Style>
                  <Style TargetType="Hyperlink">
                    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceMutedBrush}" />
                    <Setter Property="TextDecorations" Value="{x:Null}" />
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource BrandPrimaryBrush}" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Hyperlink.Style>
                <Run Text="{x:Static services:AppInfo.HomepageDisplay}" />
              </Hyperlink>
            </TextBlock>

            <!-- v15 active-provider indicator.  Visible only when
                 Provider=Ollama so the OpenRouter (default) case stays
                 quiet — adding "OpenRouter" everywhere would be visual
                 noise for the 99% case.  1-px brand-coloured outlined
                 pill (no solid fill: there is no "soft" brand brush in
                 the design tokens, and a flat brand fill would compete
                 with the SidebarTabButton selection state for visual
                 weight). -->
            <Border BorderBrush="{DynamicResource BrandPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="6,1,6,2"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Visibility="{Binding GeneralTab.IsOllamaProvider, Converter={StaticResource BoolToVisibilityConverter}}">
              <TextBlock Text="Ollama"
                         Style="{DynamicResource TypeCaption}"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource BrandPrimaryBrush}" />
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- First tab carries an extra top margin (12 vs 4 on the
             others) so it doesn't sit flush with the WindowCaption
             above — without the header.png there's nothing else to
             provide breathing room at the top of the sidebar. -->
        <controls:SidebarTabButton DockPanel.Dock="Top"
                                   Icon="{StaticResource Icon.Settings}"
                                   Label="{Binding Source={x:Static services:Translator.Instance}, Path=[tab_general]}"
                                   Command="{Binding ShowGeneralCommand}"
                                   IsSelected="{Binding IsGeneralSelected}"
                                   Margin="8,12,8,0" />
        <controls:SidebarTabButton DockPanel.Dock="Top"
                                   Icon="{StaticResource Icon.Edit3}"
                                   Label="{Binding Source={x:Static services:Translator.Instance}, Path=[tab_prompts]}"
                                   Command="{Binding ShowPromptsCommand}"
                                   IsSelected="{Binding IsPromptsSelected}"
                                   Margin="8,4,8,0" />
        <controls:SidebarTabButton DockPanel.Dock="Top"
                                   Icon="{StaticResource Icon.History}"
                                   Label="{Binding Source={x:Static services:Translator.Instance}, Path=[tab_history]}"
                                   Command="{Binding ShowHistoryCommand}"
                                   IsSelected="{Binding IsHistorySelected}"
                                   Visibility="{Binding IsHistoryAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="8,4,8,0" />
      </DockPanel>
    </Border>

    <!-- Content host. TransitioningContentControl applies the §8.3
         fade-in + slide-up motion whenever SelectedTab changes. -->
    <controls:TransitioningContentControl Content="{Binding SelectedTab}" />
  </DockPanel>
</Window>
