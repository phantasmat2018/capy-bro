<Window x:Class="CapyBro.Views.OnboardingWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Width="640"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource SurfaceCanvasBrush}"
        Title="{Binding TitleText}">

  <Window.Resources>
    <!--
      Built-in converter, key chosen to match the bindings used below.
      Window-local rather than App-level so we don't pollute the global
      resource dictionary with a one-window helper.
    -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
  </Window.Resources>

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeFixedBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <DockPanel LastChildFill="True">

    <!-- Caption strip — brand cluster ([logo] CapyBro) is rendered
         unconditionally inside WindowCaption since the rebrand.  The
         localized "Welcome to CapyBro" wordmark is also shown big as
         a Display heading in the wizard body, so duplicating it as the
         caption subtitle reads as redundant — keep the strip tidy
         (brand only) by setting ShowTitle=False. -->
    <controls:WindowCaption DockPanel.Dock="Top"
                            Title="{Binding TitleText}"
                            ShowMinMax="False"
                            ShowTitle="False" />

    <!-- Footer with Skip / Back / Next | Finish.
         "Open settings" was removed at the user's request — Done now
         transitions to Settings unconditionally (App.xaml.cs reads the
         VM's WasFinished flag and opens Settings after Finish), so a
         dedicated button on the last step would be redundant. -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SurfaceSidebarMicaBrush}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Style="{DynamicResource TypeCaption}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   Text="{Binding StepIndicator}" />

        <!-- Homepage link parked in the flex column (Grid.Column=1) so
             it appears on every wizard step without per-step duplication.
             Centered horizontally between the StepIndicator (left) and
             the navigation buttons (right).  Same visual idiom as the
             Settings sidebar footer: muted by default, BrandPrimary on
             hover, no underline at any state — quiet enough to read as
             metadata, discoverable enough that a user who wants more
             info about the product can click through. -->
        <TextBlock Grid.Column="1"
                   Style="{DynamicResource TypeCaption}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
          <Hyperlink NavigateUri="{x:Static services:AppInfo.Homepage}"
                     RequestNavigate="OnExternalLinkClick">
            <Hyperlink.Style>
              <Style TargetType="Hyperlink">
                <Setter Property="Foreground" Value="{DynamicResource OnSurfaceMutedBrush}" />
                <Setter Property="TextDecorations" Value="{x:Null}" />
                <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource BrandPrimaryBrush}" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </Hyperlink.Style>
            <Run Text="{x:Static services:AppInfo.HomepageDisplay}" />
          </Hyperlink>
        </TextBlock>

        <!-- Action buttons (right). Visibility flips per-step so we don't
             show "Back" on Welcome or "Skip" on Done.  All in one
             StackPanel so spacing stays consistent. -->
        <StackPanel Grid.Column="2" Orientation="Horizontal">
          <Button Content="{Binding BtnSkip}"
                  Command="{Binding SkipCommand}"
                  Margin="0,0,8,0">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <!-- Back stays visible on every step including the last
               (Done page) per the user's request — without it, a user
               who reached Done but wants to flip a hotkey / language /
               API-key choice would have to Skip and restart the
               wizard.  CanGoBack still gates IsEnabled so step 0
               (Welcome) shows the button greyed-out rather than
               popping it out of layout. -->
          <Button Content="{Binding BtnBack}"
                  Command="{Binding BackCommand}"
                  IsEnabled="{Binding CanGoBack}"
                  Style="{StaticResource ButtonDefault}"
                  Margin="0,0,8,0" />

          <Button Content="{Binding BtnNext}"
                  Command="{Binding NextCommand}"
                  IsEnabled="{Binding CanGoNext}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>

          <Button Content="{Binding BtnFinish}"
                  Command="{Binding FinishCommand}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsLastStep}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Page content area. Each step's panel is bound to a step-specific
         IsXxxStep boolean and toggles Visibility — keeps the markup flat
         (no DataTemplate selector) and lets every page own its own layout
         without juggling row definitions.  Explicit Background prevents
         transparent compositing from washing the headings out. -->
    <Grid Margin="32,28,32,20"
          Background="{DynamicResource SurfaceCanvasBrush}">

      <!-- Step 0: Welcome + Language picker.
           Pre-restructure Welcome and Language were two separate steps;
           merged at the user's request so a non-English speaker can flip
           the UI on the very first screen instead of clicking Next first.
           Layout: logo + heading + body across the top, then a labelled
           ComboBox immediately below — keeps the full screen scannable
           without scroll. -->
      <StackPanel Visibility="{Binding IsWelcomeStep, Converter={StaticResource BoolToVisibilityConverter}}">
        <Image Source="pack://application:,,,/assets/logo.png"
               Width="84" Height="84"
               Margin="0,0,0,16"
               HorizontalAlignment="Left" />
        <TextBlock Style="{DynamicResource TypeDisplay}"
                   Foreground="{DynamicResource OnSurfaceStrongBrush}"
                   Text="{Binding WelcomeHeading}"
                   Margin="0,0,0,10"
                   TextWrapping="Wrap" />
        <TextBlock Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                   Text="{Binding WelcomeBody}"
                   Margin="0,0,0,24"
                   TextWrapping="Wrap" />

        <TextBlock Style="{DynamicResource TypeCaption}"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   Text="{Binding LanguageHeading}"
                   Margin="0,0,0,6" />
        <!-- H23 (FZ4-F2) fix: see GeneralTab.xaml for the rationale —
             explicit ItemTemplate, not DisplayMemberPath. -->
        <ComboBox Style="{StaticResource InputComboBox}"
                  ItemsSource="{Binding AvailableLanguages}"
                  SelectedValuePath="Value"
                  SelectedValue="{Binding Language, Mode=TwoWay}"
                  Width="280"
                  HorizontalAlignment="Left">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <!-- Step 1: API key.

           Phase E iteration 2: live validation indicator under the
           input.  Same four-state visual grammar as Settings →
           General (Checking / Valid / Invalid / NetworkError) so a
           user typing a key on the very first launch sees
           identical feedback to what they'll see in Settings later.
           Indicator collapses for an empty field — the wizard's
           API-key step is optional (Skip is allowed), so we don't
           push a "fix this" badge over blank input.

           Layout: Grid with two columns, indicator on the left
           (Auto width, four mutually-exclusive Visibility-bound
           StackPanels), OpenRouter signup link on the right (Auto)
           with a "*" spacer between so the link parks on the right
           edge regardless of the indicator's width. -->
      <StackPanel Visibility="{Binding IsApiKeyStep, Converter={StaticResource BoolToVisibilityConverter}}">
        <!--
          Heading row: brand-accent strip on the left + TypeH1 text.
          Mirrors the section heading pattern the General/Prompts
          tabs use — keeps the visual grammar consistent across the
          first-launch wizard and the running app, so "this section
          is a section" reads the same way regardless of where in
          the lifecycle the user encounters it.

          SectionAccentStrip lives in Themes/Cards.xaml (App-level
          MergedDictionaries) so the StaticResource lookup walks
          from this Window up to App.Resources without needing a
          local copy.
        -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Border Style="{StaticResource SectionAccentStrip}" />
          <TextBlock Style="{DynamicResource TypeH1}"
                     Foreground="{DynamicResource OnSurfaceStrongBrush}"
                     Text="{Binding ApiKeyHeading}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>
        <TextBlock Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                   Text="{Binding ApiKeyBody}"
                   Margin="0,0,0,16"
                   TextWrapping="Wrap" />
        <controls:RevealablePasswordBox Password="{Binding ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Ollama escape hatch: users who'd rather keep text on-device
             skip the API-key entry entirely and switch provider after
             finishing the wizard.  Caption-style so it's discoverable
             without competing with the primary "paste your key" CTA. -->
        <TextBlock Style="{DynamicResource TypeCaption}"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[onboarding_apikey_ollama_hint]}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Checking: muted Loader2 with a 1-second forever rotation. -->
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Visibility="{Binding IsApiKeyChecking, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="{StaticResource Icon.Loader2}"
                  Stroke="{DynamicResource OnSurfaceMutedBrush}"
                  StrokeThickness="1.8"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Width="14" Height="14"
                  Stretch="Uniform"
                  VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
              <Path.RenderTransform>
                <RotateTransform x:Name="OnboardingLoaderRotate" Angle="0" />
              </Path.RenderTransform>
              <Path.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="OnboardingLoaderRotate"
                                       Storyboard.TargetProperty="Angle"
                                       From="0" To="360"
                                       Duration="0:0:1"
                                       RepeatBehavior="Forever" />
                    </Storyboard>
                  </BeginStoryboard>
                </EventTrigger>
              </Path.Triggers>
            </Path>
            <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[api_key_status_checking]}"
                       Style="{DynamicResource TypeCaption}"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Valid: green Check + "Key is valid". -->
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Visibility="{Binding IsApiKeyValid, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="{StaticResource Icon.Check}"
                  Stroke="{DynamicResource StatusSuccessBrush}"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Width="14" Height="14"
                  Stretch="Uniform"
                  VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[api_key_status_valid]}"
                       Style="{DynamicResource TypeCaption}"
                       Foreground="{DynamicResource StatusSuccessBrush}"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Invalid: red X + "Key is invalid". -->
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Visibility="{Binding IsApiKeyInvalid, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="{StaticResource Icon.X}"
                  Stroke="{DynamicResource StatusErrorBrush}"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Width="14" Height="14"
                  Stretch="Uniform"
                  VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[api_key_status_invalid]}"
                       Style="{DynamicResource TypeCaption}"
                       Foreground="{DynamicResource StatusErrorBrush}"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Network error: muted AlertTriangle (we can't tell if
               the key is bad, so don't tint red). -->
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Visibility="{Binding IsApiKeyNetworkError, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="{StaticResource Icon.AlertTriangle}"
                  Stroke="{DynamicResource OnSurfaceMutedBrush}"
                  StrokeThickness="1.8"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Width="14" Height="14"
                  Stretch="Uniform"
                  VerticalAlignment="Center" />
            <TextBlock Text="{Binding Source={x:Static services:Translator.Instance}, Path=[api_key_status_network]}"
                       Style="{DynamicResource TypeCaption}"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- OpenRouter signup link parked on the right. -->
          <TextBlock Grid.Column="2"
                     Style="{DynamicResource TypeCaption}"
                     Foreground="{DynamicResource OnSurfaceMutedBrush}"
                     VerticalAlignment="Center">
            <Hyperlink NavigateUri="https://openrouter.ai/"
                       RequestNavigate="OnExternalLinkClick"
                       Foreground="{DynamicResource BrandPrimaryBrush}">
              <Run Text="{Binding ApiKeyHint, Mode=OneWay}" />
            </Hyperlink>
          </TextBlock>
        </Grid>
      </StackPanel>

      <!-- Step 2: Hotkeys (improvement / menu / undo).
           Pre-restructure this step had a single ComboBox for the
           improvement hotkey only.  Expanded to all three so the user
           can resolve conflicts up front instead of bouncing into
           Settings.  HasHotkeyConflict gates Next + surfaces an inline
           red error message; same single-source-of-truth pattern as
           Settings → General. -->
      <StackPanel Visibility="{Binding IsHotkeyStep, Converter={StaticResource BoolToVisibilityConverter}}">
        <!-- Same brand-accent heading treatment as the API-key step
             (see comment there) — visual grammar parity. -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <Border Style="{StaticResource SectionAccentStrip}" />
          <TextBlock Style="{DynamicResource TypeH1}"
                     Foreground="{DynamicResource OnSurfaceStrongBrush}"
                     Text="{Binding HotkeyHeading}"
                     VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </StackPanel>
        <TextBlock Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                   Text="{Binding HotkeyBody}"
                   Margin="0,0,0,18"
                   TextWrapping="Wrap" />

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0"
                     Style="{DynamicResource TypeBody}"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     Text="{Binding HotkeyLabel}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,8" />
          <ComboBox Grid.Row="0" Grid.Column="1"
                    Style="{StaticResource InputComboBox}"
                    ItemsSource="{Binding AvailableHotkeys}"
                    Text="{Binding Hotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsEditable="True"
                    Margin="0,0,0,8" />

          <TextBlock Grid.Row="1" Grid.Column="0"
                     Style="{DynamicResource TypeBody}"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     Text="{Binding MenuHotkeyLabel}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,8" />
          <ComboBox Grid.Row="1" Grid.Column="1"
                    Style="{StaticResource InputComboBox}"
                    ItemsSource="{Binding AvailableHotkeys}"
                    Text="{Binding MenuHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsEditable="True"
                    Margin="0,0,0,8" />

          <TextBlock Grid.Row="2" Grid.Column="0"
                     Style="{DynamicResource TypeBody}"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     Text="{Binding UndoHotkeyLabel}"
                     VerticalAlignment="Center"
                     Margin="0,0,12,8" />
          <ComboBox Grid.Row="2" Grid.Column="1"
                    Style="{StaticResource InputComboBox}"
                    ItemsSource="{Binding AvailableHotkeys}"
                    Text="{Binding UndoHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    IsEditable="True"
                    Margin="0,0,0,8" />
        </Grid>

        <!-- Conflict error.  Visibility hidden when there's no clash so
             the layout doesn't jump as the user flips between values. -->
        <TextBlock Style="{DynamicResource TypeCaption}"
                   Foreground="{DynamicResource StatusErrorBrush}"
                   Text="{Binding HotkeyConflictMessage}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   Visibility="{Binding HasHotkeyConflict, Converter={StaticResource BoolToVisibilityConverter}}" />
      </StackPanel>

      <!-- Step 3: Done -->
      <StackPanel Visibility="{Binding IsDoneStep, Converter={StaticResource BoolToVisibilityConverter}}">
        <TextBlock Style="{DynamicResource TypeDisplay}"
                   Foreground="{DynamicResource OnSurfaceStrongBrush}"
                   Text="{Binding DoneHeading}"
                   Margin="0,0,0,12" />
        <TextBlock Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                   Text="{Binding DoneBody}"
                   TextWrapping="Wrap" />
      </StackPanel>

    </Grid>
  </DockPanel>
</Window>
