<Window x:Class="CapyBro.Views.DiffPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CapyBro.ViewModels"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_title]}"
        Width="980"
        Height="640"
        MinWidth="640"
        MinHeight="420"
        Background="{DynamicResource SurfaceCanvasBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeResizeBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- Per-row background tinting via DataTriggers so theme swap propagates
         (DynamicResource keeps the brush bound through Light↔Dark). The base
         Border has no background; triggers paint the tint when needed. -->
    <Style x:Key="DiffLineBorder" TargetType="Border">
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="MinHeight" Value="20" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="Inserted">
          <Setter Property="Background" Value="{DynamicResource DiffInsertBackgroundBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="Deleted">
          <Setter Property="Background" Value="{DynamicResource DiffDeleteBackgroundBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="Modified">
          <Setter Property="Background" Value="{DynamicResource DiffModifiedBackgroundBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="DiffLineTemplate" DataType="{x:Type vm:DiffLineRow}">
      <!--
        Two-column row: line-number gutter + content.  Gutter is
        fixed at 36 px so both panes' gutters always align across
        the side-by-side ScrollViewer pair (a "*"-sized gutter
        would expand for triple-digit line numbers and create
        differential widths between the two columns).  The bound
        kind tint (DiffLineBorder Style) extends across both gutter
        AND content — the triggers paint the outer Border's
        Background, which both inner pieces sit on.
      -->
      <Border Style="{StaticResource DiffLineBorder}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!--
            Line-number gutter.  TextBlock binds to LineNumber (int?)
            — WPF renders null as empty string, so Imaginary rows
            (alignment padding from the differ) show a blank
            gutter cell while the row still occupies its layout
            slot.  Right-aligned + monospace so multi-digit numbers
            stay vertically tidy.  Faint OnSurfaceMuted brush keeps
            the gutter subordinate to the diff content.
          -->
          <TextBlock Grid.Column="0"
                     Text="{Binding LineNumber}"
                     Foreground="{DynamicResource OnSurfaceMutedBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="11"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,2,8,0" />

          <TextBlock Grid.Column="1"
                     Text="{Binding Text}"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <DockPanel LastChildFill="True">

    <controls:WindowCaption DockPanel.Dock="Top"
                            Title="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_title]}"
                            ShowMinMax="True"
                            ShowTitle="True" />

    <Grid Margin="20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!--
        Top row: subtitle on the left, Edit/Diff view toggle on the right.
        Toggle is a CheckBox bound to IsEditMode (TwoWay) styled like a
        compact pill button — keeps the chrome calm.  When checked,
        right pane swaps from the side-by-side diff rows to a single
        editable TextBox; back to unchecked recomputes the diff against
        the edited text via DiffPreviewViewModel.OnIsEditModeChanged.
      -->
      <Grid Grid.Row="0" Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_subtitle]}"
                   Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />

        <CheckBox Grid.Column="1"
                  IsChecked="{Binding IsEditMode, Mode=TwoWay}"
                  Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_edit_mode]}"
                  Style="{StaticResource DefaultCheckBox}"
                  VerticalAlignment="Center"
                  Margin="12,0,0,0" />
      </Grid>

      <!--
        Stats chip strip (Phase E #13).  Three Pill-style chips
        showing inserted / deleted / modified counts at a glance —
        same visual rhythm as GitHub's PR diff stats.  Each chip is
        a Border tinted with the matching diff colour at low alpha
        (DiffInsert/DiffDelete/DiffModifiedBackgroundBrush — same
        brushes the per-line backgrounds use, so the user immediately
        associates each chip with its diff colour).

        Padding 8,3 + CornerRadius 10 gives a pill shape; FontSize 12
        keeps the strip visually subordinate to the column headers
        below.  + / - / ~ glyphs are conventional diff notation
        (no localisation needed for the symbols themselves; the
        numbers are the actionable content).
      -->
      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Margin="0,0,0,12">
        <Border Background="{DynamicResource DiffInsertBackgroundBrush}"
                CornerRadius="10"
                Padding="10,3"
                Margin="0,0,8,0">
          <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="12">
            <Run Text="+ " />
            <Run Text="{Binding InsertedCount, Mode=OneWay}" />
          </TextBlock>
        </Border>
        <Border Background="{DynamicResource DiffDeleteBackgroundBrush}"
                CornerRadius="10"
                Padding="10,3"
                Margin="0,0,8,0">
          <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="12">
            <Run Text="− " />
            <Run Text="{Binding DeletedCount, Mode=OneWay}" />
          </TextBlock>
        </Border>
        <Border Background="{DynamicResource DiffModifiedBackgroundBrush}"
                CornerRadius="10"
                Padding="10,3">
          <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="12">
            <Run Text="~ " />
            <Run Text="{Binding ModifiedCount, Mode=OneWay}" />
          </TextBlock>
        </Border>
      </StackPanel>

      <!-- Column headers -->
      <Grid Grid.Row="2" Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_original]}"
                   Style="{DynamicResource TypeBodyStrong}" />

        <TextBlock Grid.Column="2"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_improved]}"
                   Style="{DynamicResource TypeBodyStrong}" />
      </Grid>

      <!-- Side-by-side panes. ItemsControl + ScrollViewer chosen over
           ListBox because we don't want item selection chrome (focus
           rectangle, hover/select states) on diff rows — they're read-only
           data, not interactive selectors. UI virtualization for large
           texts is enabled via VirtualizingStackPanel below. -->
      <Grid Grid.Row="3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceLayer1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6">
          <ScrollViewer x:Name="OriginalScroller"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        ScrollChanged="OriginalScroller_ScrollChanged">
            <ItemsControl ItemsSource="{Binding OriginalLines}"
                          ItemTemplate="{StaticResource DiffLineTemplate}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="False">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <VirtualizingStackPanel />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!--
          Improved pane.  Hosts BOTH the read-only diff scroller AND the
          edit-mode TextBox in the SAME visual slot; only one is visible
          at a time, swapped via Visibility bindings driven by IsEditMode.
          BoolToVisibilityNot inverts so the diff scroller hides when
          edit mode is on; both share the same Border so the chrome stays
          consistent across the toggle.
        -->
        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceLayer1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6">
          <Grid>
            <ScrollViewer x:Name="ImprovedScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ScrollChanged="ImprovedScroller_ScrollChanged"
                          Visibility="{Binding DiffViewVisibility}">
              <ItemsControl ItemsSource="{Binding ImprovedLines}"
                            ItemTemplate="{StaticResource DiffLineTemplate}"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="False">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>

            <!--
              Edit-mode surface: single multi-line TextBox bound to
              EditableImproved (TwoWay).  No line-by-line diff coloring
              here — users editing get a clean writing surface; flipping
              back to Diff view recomputes the colored side-by-side.
              AcceptsReturn for newlines, BorderThickness=0 because the
              outer Border already provides the chrome (avoids double
              border on focus).  Monospace font matches the diff rows so
              text widths stay consistent across the toggle.
            -->
            <TextBox x:Name="ImprovedEditor"
                     Text="{Binding EditableImproved, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding EditViewVisibility}"
                     IsVisibleChanged="ImprovedEditor_IsVisibleChanged"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="13"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     Background="{DynamicResource SurfaceLayer1Brush}"
                     BorderThickness="0"
                     Padding="6,4" />
          </Grid>
        </Border>
      </Grid>

      <!-- Action footer: Reject left-most (lowest commitment), Regenerate
           middle, Accept (Primary, IsDefault) right-most. Matches §7.10
           dialog idiom — primary CTA on the right. -->
      <StackPanel Grid.Row="4"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,16,0,0">
        <Button x:Name="RejectButton"
                Style="{StaticResource ButtonDefault}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_reject]}"
                Click="OnReject"
                IsCancel="True"
                MinWidth="100"
                Margin="0,0,8,0" />
        <Button x:Name="RegenerateButton"
                Style="{StaticResource ButtonDefault}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_regenerate]}"
                Click="OnRegenerate"
                MinWidth="120"
                Margin="0,0,8,0" />
        <Button x:Name="AcceptButton"
                Style="{StaticResource ButtonPrimary}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_accept]}"
                Click="OnAccept"
                IsDefault="True"
                MinWidth="100" />
      </StackPanel>
    </Grid>
  </DockPanel>
</Window>
