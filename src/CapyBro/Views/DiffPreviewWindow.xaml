<Window x:Class="CapyBro.Views.DiffPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CapyBro.ViewModels"
        xmlns:controls="clr-namespace:CapyBro.Controls"
        xmlns:services="clr-namespace:CapyBro.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_title]}"
        Width="980"
        Height="640"
        MinWidth="640"
        MinHeight="420"
        Background="{DynamicResource SurfaceCanvasBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="True">

  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="36"
                        ResizeBorderThickness="{StaticResource WindowChromeResizeBorder}"
                        GlassFrameThickness="0"
                        UseAeroCaptionButtons="False"
                        CornerRadius="0" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <!-- Per-row background tinting via DataTriggers so theme swap propagates
         (DynamicResource keeps the brush bound through Light↔Dark). The base
         Border has no background; triggers paint the tint when needed. -->
    <Style x:Key="DiffLineBorder" TargetType="Border">
      <Setter Property="Padding" Value="6,1" />
      <Setter Property="MinHeight" Value="20" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding Kind}" Value="Inserted">
          <Setter Property="Background" Value="{DynamicResource DiffInsertBackgroundBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="Deleted">
          <Setter Property="Background" Value="{DynamicResource DiffDeleteBackgroundBrush}" />
        </DataTrigger>
        <DataTrigger Binding="{Binding Kind}" Value="Modified">
          <Setter Property="Background" Value="{DynamicResource DiffModifiedBackgroundBrush}" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="DiffLineTemplate" DataType="{x:Type vm:DiffLineRow}">
      <Border Style="{StaticResource DiffLineBorder}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="{Binding LineNumber}"
                     Foreground="{DynamicResource OnSurfaceMutedBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="11"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,2,8,0" />

          <TextBlock Grid.Column="1"
                     Text="{Binding Text}"
                     Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="13"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>
    </DataTemplate>

    <!--
      Pane-header strip used inside both Borders below.  Subtle tint that
      reads as "this is a header, not content" without taking colour
      attention away from the diff rows.
    -->
    <Style x:Key="PaneHeaderBorder" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource SurfaceLayer2Brush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="12,8" />
    </Style>

    <!--
      Pane title (Original / Result) sitting inside each pane header.
      Smaller + muted vs the section h2 above so the eye reads them as
      labels, not content headers.
    -->
    <Style x:Key="PaneTitle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{DynamicResource FontPrimary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource OnSurfaceMutedBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <!-- Hand-tuned letter-spacing to read as a small-caps-ish label. -->
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>
  </Window.Resources>

  <DockPanel LastChildFill="True">

    <controls:WindowCaption DockPanel.Dock="Top"
                            Title="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_title]}"
                            ShowMinMax="True"
                            ShowTitle="True" />

    <Grid Margin="20,16,20,16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!--
        Row 0 — header strip with subtitle on the left and the stats
        chips on the right.  Stats chips show only the kinds that
        actually occurred (each one hides when its count is 0), so a
        pure-translation prompt with only modifications shows just
        one amber "~N" chip instead of three with two zeros.  When
        the AI produced an identical result, a single muted "No
        changes" pill replaces the chips entirely.
      -->
      <Grid Grid.Row="0" Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_preview_subtitle]}"
                   Style="{DynamicResource TypeBody}"
                   Foreground="{DynamicResource OnSurfaceMutedBrush}"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Border Background="{DynamicResource DiffInsertBackgroundBrush}"
                  CornerRadius="10"
                  Padding="10,3"
                  Margin="0,0,6,0"
                  Visibility="{Binding InsertedChipVisibility}">
            <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="12">
              <Run Text="+ " />
              <Run Text="{Binding InsertedCount, Mode=OneWay}" />
            </TextBlock>
          </Border>
          <Border Background="{DynamicResource DiffDeleteBackgroundBrush}"
                  CornerRadius="10"
                  Padding="10,3"
                  Margin="0,0,6,0"
                  Visibility="{Binding DeletedChipVisibility}">
            <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="12">
              <Run Text="− " />
              <Run Text="{Binding DeletedCount, Mode=OneWay}" />
            </TextBlock>
          </Border>
          <Border Background="{DynamicResource DiffModifiedBackgroundBrush}"
                  CornerRadius="10"
                  Padding="10,3"
                  Visibility="{Binding ModifiedChipVisibility}">
            <TextBlock Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="12">
              <Run Text="~ " />
              <Run Text="{Binding ModifiedCount, Mode=OneWay}" />
            </TextBlock>
          </Border>

          <!--
            "No changes" pill — muted outline style replaces the
            three coloured chips when the AI returned identical text.
            Without it the chip strip went empty and the header
            looked like the data was still loading.
          -->
          <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="10,3"
                  Visibility="{Binding IsIdentical}">
            <TextBlock Foreground="{DynamicResource OnSurfaceMutedBrush}"
                       Style="{DynamicResource TypeCaption}"
                       Text="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_no_changes]}" />
          </Border>
        </StackPanel>
      </Grid>

      <!--
        Row 1 — side-by-side panes.  Each pane has its own integrated
        header (label + content area) so the column titles stay
        attached to their content even when the user resizes the
        window.  The right pane's header carries the Edit toggle —
        contextually placed next to the surface it controls instead
        of floating in the window chrome.
      -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Original pane (read-only) -->
        <Border Grid.Column="0"
                Background="{DynamicResource SurfaceLayer1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
              <TextBlock Style="{StaticResource PaneTitle}"
                         Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_original]}" />
            </Border>

            <ScrollViewer x:Name="OriginalScroller"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ScrollChanged="OriginalScroller_ScrollChanged">
              <ItemsControl ItemsSource="{Binding OriginalLines}"
                            ItemTemplate="{StaticResource DiffLineTemplate}"
                            VirtualizingStackPanel.IsVirtualizing="True"
                            VirtualizingStackPanel.VirtualizationMode="Recycling"
                            ScrollViewer.CanContentScroll="False">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <!--
          Result pane — read-only diff scroller OR editable TextBox in
          the same visual slot, swapped via Visibility bindings on the
          IsEditMode VM property.  Edit toggle lives in this pane's
          header (top-right corner) because that's the surface it
          controls; placing it in the window chrome made it feel
          disconnected from the action it triggered.
        -->
        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceLayer1Brush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PaneHeaderBorder}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{StaticResource PaneTitle}"
                           Text="{Binding Source={x:Static services:Translator.Instance}, Path=[history_label_improved]}" />

                <CheckBox Grid.Column="1"
                          IsChecked="{Binding IsEditMode, Mode=TwoWay}"
                          Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_edit_mode]}"
                          Style="{StaticResource DefaultCheckBox}"
                          VerticalAlignment="Center" />
              </Grid>
            </Border>

            <Grid Grid.Row="1">
              <ScrollViewer x:Name="ImprovedScroller"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            ScrollChanged="ImprovedScroller_ScrollChanged"
                            Visibility="{Binding DiffViewVisibility}">
                <ItemsControl ItemsSource="{Binding ImprovedLines}"
                              ItemTemplate="{StaticResource DiffLineTemplate}"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="False">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                </ItemsControl>
              </ScrollViewer>

              <TextBox x:Name="ImprovedEditor"
                       Text="{Binding EditableImproved, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Visibility="{Binding EditViewVisibility}"
                       IsVisibleChanged="ImprovedEditor_IsVisibleChanged"
                       AcceptsReturn="True"
                       AcceptsTab="True"
                       TextWrapping="Wrap"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="13"
                       Foreground="{DynamicResource OnSurfaceDefaultBrush}"
                       Background="{DynamicResource SurfaceLayer1Brush}"
                       BorderThickness="0"
                       Padding="6,4" />
            </Grid>
          </Grid>
        </Border>
      </Grid>

      <!--
        Row 2 — hairline divider separating the content from the
        action footer.  Without it the buttons sat directly under
        the bordered panes and the whole bottom looked unfinished.
      -->
      <Border Grid.Row="2"
              Height="1"
              Background="{DynamicResource BorderSubtleBrush}"
              Margin="0,16,0,0" />

      <!-- Action footer: Reject (lowest commitment), Regenerate, Accept
           (Primary, IsDefault). Matches §7.10 dialog idiom — primary
           CTA right-most. -->
      <StackPanel Grid.Row="3"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,14,0,0">
        <Button x:Name="RejectButton"
                Style="{StaticResource ButtonDefault}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_reject]}"
                Click="OnReject"
                IsCancel="True"
                MinWidth="100"
                Margin="0,0,8,0" />
        <Button x:Name="RegenerateButton"
                Style="{StaticResource ButtonDefault}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_regenerate]}"
                Click="OnRegenerate"
                MinWidth="120"
                Margin="0,0,8,0" />
        <Button x:Name="AcceptButton"
                Style="{StaticResource ButtonPrimary}"
                Content="{Binding Source={x:Static services:Translator.Instance}, Path=[diff_btn_accept]}"
                Click="OnAccept"
                IsDefault="True"
                MinWidth="100" />
      </StackPanel>
    </Grid>
  </DockPanel>
</Window>
